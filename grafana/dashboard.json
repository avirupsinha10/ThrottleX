{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "gauge",      "name": "Gauge",       "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (last 5 m)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(throttlex_requests_total[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Allowed Rate",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(throttlex_allowed_requests_total[1m]))",
          "legendFormat": "Allowed/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": null }] } }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Rejected Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(throttlex_rejected_requests_total[1m]))",
          "legendFormat": "Rejected/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Circuit Breaker State",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "throttlex_circuit_breaker_state",
          "legendFormat": "State"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 2 }
          ]
        },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "CLOSED" }, "1": { "text": "HALF-OPEN" }, "2": { "text": "OPEN" } } }
        ]
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Throughput (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (allowed) (rate(throttlex_requests_total[1m]))",
          "legendFormat": "allowed={{allowed}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Latency Percentiles (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(throttlex_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(throttlex_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(throttlex_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } }
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis Operation Latency by Algorithm (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(throttlex_redis_operation_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{operation}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Throughput by Algorithm (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (algorithm) (rate(throttlex_requests_total[1m]))",
          "legendFormat": "{{algorithm}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },

    {
      "id": 9,
      "type": "gauge",
      "title": "Active Rate-Limit Keys",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "throttlex_active_keys",
          "legendFormat": "Keys"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 }] } }
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Process Memory (MB)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS MB"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "MB" }
      }
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["throttlex", "rate-limiting"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ThrottleX — Rate Limiter",
  "uid": "throttlex-main",
  "version": 1
}
