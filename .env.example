PORT=3000
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=throttlex:
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=2000

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_SUCCESS_THRESHOLD=2
CB_TIMEOUT=30000

# Rate Limiter Defaults
DEFAULT_ALGORITHM=sliding-window-counter
DEFAULT_LIMIT=100
DEFAULT_WINDOW_MS=60000
FALLBACK_ALLOWED=true

# Logging
LOG_LEVEL=info

# Metrics
METRICS_PREFIX=throttlex_
